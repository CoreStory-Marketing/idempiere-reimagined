# Backend API base URL — used server-side by the proxy route handler.
# In Docker Compose this defaults to http://api-gateway:8080.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: enable mock fallback when the backend is unreachable in dev mode only.
# Do NOT set this for the demo recording — the demo uses the real backend.
MOCK_ENABLED=false
